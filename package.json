{
  "name": "paperlens",
  "description": "PaperLens - arXiv 论文解读 / 公式推导 / Markdown 导出 Chrome 扩展",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test:pdf": "node --experimental-strip-types --test tests/pdf*.test.mjs",
    "test:phase-b:browser": "pnpm build && node tests/phaseB.browser-smoke.mjs",
    "test:phase-b:permissions": "pnpm build && node tests/phaseB.browser-smoke.mjs --interactive-permissions",
    "test:phase-c:browser": "pnpm build && node tests/phaseB.browser-smoke.mjs --phase-c",
    "test:phase-c:browser:offline": "pnpm build && node tests/phaseB.browser-smoke.mjs --phase-c --offline",
    "test:mineru:browser": "pnpm build && node tests/phaseB.browser-smoke.mjs --mineru",
    "test:phase-d:ocr-poc": "node --test tests/pdfOcrPoc.test.mjs tests/mineruPoc.test.mjs && node tests/phaseD.ocr-poc.mjs validate",
    "test:mineru:client": "node --experimental-strip-types --test tests/mineruClient.test.mjs tests/pdfFormulaProvider.test.mjs",
    "poc:mineru:run": "node tests/helpers/runMineruPoc.mjs",
    "poc:mineru:adapt": "node tests/helpers/adaptMineruRun.mjs",
    "poc:mineru:review": "node tests/helpers/buildOcrReviewTemplate.mjs",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "dompurify": "^3.4.1",
    "katex": "^0.16.45",
    "marked": "^18.0.2",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "wxt": "^0.20.25"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
