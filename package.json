    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
