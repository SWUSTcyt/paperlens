{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paperlens.local/schemas/mineru/v1/error.schema.json",
  "title": "PaperLens MinerU Error v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "requestId", "error"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "requestId": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,64}$" },
    "error": { "$ref": "#/$defs/error" }
  },
  "$defs": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "AUTH_REQUIRED",
            "AUTH_INVALID",
            "CONFIG_INVALID",
            "VERSION_INCOMPATIBLE",
            "INVALID_REQUEST",
            "PDF_INVALID",
            "PDF_TOO_LARGE",
            "PDF_TOO_MANY_PAGES",
            "SERVICE_NOT_READY",
            "QUEUE_FULL",
            "JOB_NOT_FOUND",
            "JOB_FAILED",
            "JOB_CANCELLED",
            "JOB_TIMED_OUT",
            "RESULT_INVALID",
            "INTERNAL_ERROR"
          ]
        },
        "message": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    }
  }
}
